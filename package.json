{
  "name": "descript-streamdeck",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "packages/plugin",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run build:shared && npm run build:helper && npm run build:plugin",
    "build:helper": "swift build --package-path packages/helper -c release && node scripts/copy-helper.mjs",
    "build:plugin": "npm --workspace @descript-streamdeck/plugin run build",
    "build:shared": "npm --workspace @descript-streamdeck/shared run build",
    "check": "npm run typecheck",
    "clean": "rm -rf packages/plugin/com.descript.streamdeck.sdPlugin/dist packages/plugin/com.descript.streamdeck.sdPlugin/bin packages/shared/dist packages/helper/.build",
    "drill:recorder": "node scripts/live-recorder-drill.mjs",
    "package:plugin": "npm run build && node scripts/package-plugin.mjs",
    "release:check": "node scripts/release-check.mjs",
    "typecheck": "npm --workspaces --if-present run typecheck && swift build --package-path packages/helper"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
